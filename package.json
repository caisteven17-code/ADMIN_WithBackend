{
  "name": "hopecard-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "node scripts/check-node-version.js",
    "postinstall": "npm run setup:all && node scripts/setup-env.js",
    "setup:all": "npm run setup:backend",
    "setup:backend": "cd backend && npm install",
    "dev": "node scripts/check-env.js && concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "next build",
    "build:backend": "cd backend && npm run build",
    "start": "concurrently \"next start\" \"cd backend && npm start\"",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.3",
    "nodemailer": "^8.0.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "typescript": "^5"
  }
}
