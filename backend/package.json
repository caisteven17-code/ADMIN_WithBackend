{
  "name": "hopecard-admin-backend",
  "version": "1.0.0",
  "description": "HopeCard Admin Backend - NestJS Microservices API",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:beneficiary\" \"npm run dev:approvals\" \"npm run dev:analytics\"",
    "dev:gateway": "ts-node -r tsconfig-paths/register services/gateway/src/main.ts",
    "dev:auth": "ts-node -r tsconfig-paths/register services/auth/src/main.ts",
    "dev:beneficiary": "ts-node -r tsconfig-paths/register services/beneficiary/src/main.ts",
    "dev:approvals": "ts-node -r tsconfig-paths/register services/approvals/src/main.ts",
    "dev:analytics": "ts-node -r tsconfig-paths/register services/analytics/src/main.ts",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.10",
    "@nestjs/core": "^10.2.10",
    "@nestjs/microservices": "^10.4.22",
    "@nestjs/platform-express": "^10.2.10",
    "@supabase/supabase-js": "^2.38.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "express-http-proxy": "^2.1.2",
    "nodemailer": "^8.0.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@types/express": "^4.17.21",
    "@types/express-http-proxy": "^1.6.7",
    "@types/node": "^20.10.5",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
