# Backend Configuration (.env)
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# JWT Secret (change this in production!)
JWT_SECRET=your-secret-key-change-in-production

# === EMAIL CONFIGURATION ===
# Choose ONE option below and uncomment

# Option 1: Gmail (Recommended - requires App Password)
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Option 2: Generic SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourcompany.com

# Option 3: Development (Console Logging)
# Leave both options above commented out to see OTP in console
